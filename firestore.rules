rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-All default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED REUSABLE FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "sheilawalshsheila@gmail.com";
    }

    function isSeedUser(uid) {
      return uid == 'alex-uid' || uid == 'jacob-uid' || uid == 'kat-uid' || uid == 'jessica-uid' || uid == 'steve-uid' || uid == 'umt-uid' || uid == 'clara-uid' || uid == 'marcus-uid';
    }

    function isStringOrTimestamp(val) {
      return val is string || val is timestamp;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY SCHEMA VALIDATION BLUEPRINTS ---
    
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.fullName is string && data.fullName.size() <= 100
        && data.username is string && data.username.size() <= 60
        && data.email is string && data.email.size() <= 150
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000))
        && (!('userType' in data) || data.userType in ['student', 'teacher', 'institute', 'individual', 'creator', 'business'])
        && (!('profilePhoto' in data) || (data.profilePhoto is string && data.profilePhoto.size() <= 1000))
        && (!('coverPhoto' in data) || (data.coverPhoto is string && data.coverPhoto.size() <= 1000))
        && (!('website' in data) || (data.website is string && data.website.size() <= 500))
        && (!('location' in data) || (data.location is string && data.location.size() <= 200))
        && (!('followersCount' in data) || (data.followersCount is int || data.followersCount is float))
        && (!('followingCount' in data) || (data.followingCount is int || data.followingCount is float))
        && (!('postsCount' in data) || (data.postsCount is int || data.postsCount is float))
        && (!('verified' in data) || data.verified is bool)
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidPost(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && data.text is string && data.text.size() <= 5000
        && (!('mediaUrls' in data) || (data.mediaUrls is list && data.mediaUrls.size() <= 15))
        && (!('mediaType' in data) || data.mediaType in ['image', 'video', 'none'])
        && (!('likesCount' in data) || (data.likesCount is int || data.likesCount is float))
        && (!('commentsCount' in data) || (data.commentsCount is int || data.commentsCount is float))
        && (!('sharesCount' in data) || (data.sharesCount is int || data.sharesCount is float))
        && (!('hashtags' in data) || (data.hashtags is list && data.hashtags.size() <= 20))
        && (!('location' in data) || (data.location is string && data.location.size() <= 200))
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidComment(data) {
      return data.id is string && data.id.size() <= 128
        && data.postId is string
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && data.text is string && data.text.size() <= 2000
        && (!('parentId' in data) || (data.parentId == null || data.parentId is string))
        && (!('likesCount' in data) || (data.likesCount is int || data.likesCount is float))
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidLike(data) {
      return data.id is string && data.id.size() <= 128
        && data.targetId is string
        && data.targetType in ['post', 'comment']
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidFollower(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string
        && data.followerId is string && (data.followerId == request.auth.uid || isAdmin() || isSeedUser(data.followerId))
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidStory(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && data.mediaUrl is string && data.mediaUrl.size() <= 1000
        && (!('mediaType' in data) || data.mediaType in ['image', 'video'])
        && isStringOrTimestamp(data.createdAt)
        && isStringOrTimestamp(data.expiresAt);
    }

    function isValidConversation(data) {
      return data.id is string && data.id.size() <= 128
        && data.participantIds is list && data.participantIds.size() == 2
        && (request.auth.uid in data.participantIds || isAdmin() || isSeedUser(data.participantIds[0]) || isSeedUser(data.participantIds[1]))
        && (!('lastMessageText' in data) || (data.lastMessageText is string && data.lastMessageText.size() <= 1000))
        && (!('lastMessageSenderId' in data) || data.lastMessageSenderId is string)
        && (!('lastMessageTime' in data) || isStringOrTimestamp(data.lastMessageTime));
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.conversationId is string
        && data.senderId is string && (data.senderId == request.auth.uid || isAdmin() || isSeedUser(data.senderId))
        && data.receiverId is string
        && (!('text' in data) || (data.text is string && data.text.size() <= 5000))
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 1000))
        && (!('mediaType' in data) || data.mediaType in ['text', 'image'])
        && (!('read' in data) || data.read is bool)
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128
        && data.receiverId is string
        && data.senderId is string && (data.senderId == request.auth.uid || isAdmin() || isSeedUser(data.senderId))
        && data.type in ['follower', 'like', 'comment', 'message', 'mention']
        && (!('text' in data) || (data.text is string && data.text.size() <= 1000))
        && (!('read' in data) || data.read is bool)
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidSavedPost(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && data.postId is string
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.reporterId is string && (data.reporterId == request.auth.uid || isAdmin() || isSeedUser(data.reporterId))
        && data.targetId is string
        && data.targetType in ['post', 'comment']
        && data.reason is string && data.reason.size() <= 1000
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidReel(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && data.fullName is string
        && data.username is string
        && (!('profilePhoto' in data) || data.profilePhoto is string)
        && data.videoUrl is string && data.videoUrl.size() <= 2000
        && (!('caption' in data) || (data.caption is string && data.caption.size() <= 2000))
        && (!('likesCount' in data) || (data.likesCount is int || data.likesCount is float))
        && (!('commentsCount' in data) || (data.commentsCount is int || data.commentsCount is float))
        && (!('sharesCount' in data) || (data.sharesCount is int || data.sharesCount is float))
        && isStringOrTimestamp(data.createdAt);
    }

    function isValidUserActivity(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && (data.userId == request.auth.uid || isAdmin() || isSeedUser(data.userId))
        && (!('fullName' in data) || data.fullName is string)
        && (!('username' in data) || data.username is string)
        && (!('profilePhoto' in data) || data.profilePhoto is string)
        && data.activityType in ["signup", "login", "create_post", "delete_post", "like_post", "add_comment", "follow", "unfollow", "send_message", "create_story", "create_reel"]
        && data.activityDetails is string && data.activityDetails.size() <= 2000
        && (!('targetId' in data) || data.targetId is string)
        && isStringOrTimestamp(data.createdAt);
    }

    // --- COLLECTION PATH MATCHERS ---

    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSeedUser(userId)) && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSeedUser(userId)) && isValidUser(incoming()) && (
        isAdmin() || isSeedUser(userId) || incoming().diff(existing()).affectedKeys().hasOnly([
          'fullName', 'bio', 'profilePhoto', 'coverPhoto', 'website', 'location', 
          'followersCount', 'followingCount', 'postsCount'
        ])
      );
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSeedUser(userId));
    }

    match /posts/{postId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidPost(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Action: Self edit
        (existing().userId == request.auth.uid && isValidPost(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly([
          'text', 'mediaUrls', 'location', 'hashtags', 'likesCount', 'commentsCount'
        ])) ||
        // Action: Client interaction (increment likes or comment counts)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount']))
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin() || isSeedUser(existing().userId));
    }

    match /comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidComment(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (existing().userId == request.auth.uid && isValidComment(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['text'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']))
      );
      allow delete: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        get(/databases/$(database)/documents/posts/$(existing().postId)).data.userId == request.auth.uid ||
        isAdmin() ||
        isSeedUser(existing().userId)
      );
    }

    match /likes/{likeId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidLike(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin() || isSeedUser(existing().userId));
    }

    match /followers/{followerId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().followerId == request.auth.uid || isAdmin() || isSeedUser(incoming().followerId)) && isValidFollower(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && (existing().followerId == request.auth.uid || isAdmin() || isSeedUser(existing().followerId));
    }

    match /stories/{storyId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidStory(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin() || isSeedUser(existing().userId));
    }

    match /conversations/{conversationId} {
      allow read, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds || isAdmin() || isSeedUser(resource.data.participantIds[0]) || isSeedUser(resource.data.participantIds[1]));
      allow create: if isSignedIn() && (request.auth.uid in incoming().participantIds || isAdmin() || isSeedUser(incoming().participantIds[0]) || isSeedUser(incoming().participantIds[1])) && isValidConversation(incoming());
      allow update: if isSignedIn() && (request.auth.uid in existing().participantIds || isAdmin() || isSeedUser(existing().participantIds[0]) || isSeedUser(existing().participantIds[1])) && (
        isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['lastMessageText', 'lastMessageTime', 'lastMessageSenderId', 'unreadCount'])
      );
      allow delete: if false;

      // Subcollection messages
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds || isAdmin() || isSeedUser(get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds[0]) || isSeedUser(get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds[1]));
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds || isAdmin() || isSeedUser(incoming().senderId)) && (incoming().senderId == request.auth.uid || isAdmin() || isSeedUser(incoming().senderId)) && isValidMessage(incoming());
        allow update: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds || isAdmin() || isSeedUser(incoming().senderId)) && (incoming().diff(existing()).affectedKeys().hasOnly(['read']) || isAdmin());
        allow delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read, list: if isSignedIn() && (resource.data.receiverId == request.auth.uid || isAdmin() || isSeedUser(resource.data.receiverId));
      allow create: if isSignedIn() && (incoming().senderId == request.auth.uid || isAdmin() || isSeedUser(incoming().senderId)) && isValidNotification(incoming());
      allow update: if isSignedIn() && (existing().receiverId == request.auth.uid || isAdmin() || isSeedUser(existing().receiverId)) && (incoming().diff(existing()).affectedKeys().hasOnly(['read']) || isAdmin());
      allow delete: if isSignedIn() && (existing().receiverId == request.auth.uid || isAdmin() || isSeedUser(existing().receiverId));
    }

    match /savedPosts/{savedPostId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isSeedUser(resource.data.userId));
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidSavedPost(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin() || isSeedUser(existing().userId));
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && (incoming().reporterId == request.auth.uid || isAdmin() || isSeedUser(incoming().reporterId)) && isValidReport(incoming());
      allow update, delete: if isSignedIn();
    }

    match /reels/{reelId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidReel(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'sharesCount']) || isAdmin()
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin() || isSeedUser(existing().userId));
    }

    match /userActivities/{activityId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || isSeedUser(incoming().userId)) && isValidUserActivity(incoming());
      allow update, delete: if false;
    }
  }
}
